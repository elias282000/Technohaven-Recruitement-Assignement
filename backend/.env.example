APP_NAME=Real-Time Service Request Management System
APP_ENVIRONMENT=development
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/service_request_db
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PENDING_PROCESSING_DELAY_SECONDS=5
COMPLETION_PROCESSING_DELAY_SECONDS=10
